<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="utf-8">
	<meta name="viewport" content="width=device-width, initial-scale=1">
	<title>CleanX Login</title>
	<link rel="stylesheet" href="/luci-static/cleanx/css/style.css">
</head>
<body>
	<div class="cleanx-shell">
		<header class="cleanx-topbar">
			<div class="cleanx-brand">
				<img class="cleanx-logo" src="/luci-static/cleanx/assets/logo.svg" alt="CleanX">
				<span>CleanX</span>
			</div>
			<div class="cleanx-version">Login</div>
		</header>
		<main class="cleanx-main" id="maincontent">
			<div class="cbi-map">
				<h2>Authorization Required</h2>
				<p>Please log in to continue.</p>
				<form method="post" action="">
					<div class="cbi-section">
						<div class="cbi-value">
							<label class="cbi-value-title" for="luci_username">Username</label>
							<div class="cbi-value-field">
								<input id="luci_username" name="luci_username" type="text" autocomplete="username" autofocus>
							</div>
						</div>
						<div class="cbi-value">
							<label class="cbi-value-title" for="luci_password">Password</label>
							<div class="cbi-value-field">
								<input id="luci_password" name="luci_password" type="password" autocomplete="current-password">
							</div>
						</div>
						<div class="cbi-page-actions">
							<button class="cbi-button cbi-button-positive" type="submit">Login</button>
						</div>
					</div>
				</form>
			</div>
		</main>
	</div>
</body>
</html>
