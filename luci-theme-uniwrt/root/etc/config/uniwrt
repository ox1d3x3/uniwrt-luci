config global 'global'
	# Theme mode: auto (follow system) | light | dark
	option mode 'auto'
	# Accent colour used in light mode
	option accent '#006fff'
	# Accent colour used in dark mode
	option dark_accent '#4797ff'
	# Show the live status bar (CPU / RAM / throughput / uptime) in the header
	option status_bar '1'
	# Show the custom UniWRT overview dashboard menu entry
	option overview '1'
	# Base font size in px
	option font_size '14'
	# Start with the navigation rail collapsed on desktop
	option rail_collapsed '0'
