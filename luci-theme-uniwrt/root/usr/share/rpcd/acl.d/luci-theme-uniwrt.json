{
	"luci-theme-uniwrt": {
		"description": "Grant access to UniWRT theme settings and overview widgets",
		"read": {
			"uci": [
				"uniwrt",
				"luci"
			],
			"ubus": {
				"system": [
					"board",
					"info"
				],
				"luci-rpc": [
					"getBoardJSON",
					"getHostHints",
					"getNetworkDevices",
					"getWirelessDevices"
				],
				"network.interface": [
					"dump"
				],
				"network.device": [
					"status"
				],
				"network": [
					"get_proto_handlers"
				],
				"iwinfo": [
					"assoclist",
					"info"
				],
				"luci": [
					"getRealtimeStats"
				]
			},
			"file": {
				"/proc/cpuinfo": [
					"read"
				]
			}
		},
		"write": {
			"uci": [
				"uniwrt"
			]
		}
	}
}
