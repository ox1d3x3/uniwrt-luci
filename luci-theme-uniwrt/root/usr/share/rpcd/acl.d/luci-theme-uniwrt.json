{
	"luci-theme-uniwrt": {
		"description": "Grant access to UniWRT theme settings and overview widgets",
		"read": {
			"uci": [ "uniwrt", "luci" ],
			"ubus": {
				"system": [ "board", "info" ],
				"luci-rpc": [ "getHostHints", "getWirelessDevices" ],
				"network.interface": [ "dump" ],
				"network.device": [ "status" ]
			},
			"file": {
				"/proc/cpuinfo": [ "read" ]
			}
		},
		"write": {
			"uci": [ "uniwrt" ]
		}
	}
}
